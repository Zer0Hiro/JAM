BPM 100

INSTRUMENT pluck:
    TYPE SYNTH
    WAVE TRIANGLE
    ADSR 2 80 0 60
    VOLUME 200

INSTRUMENT pad:
    TYPE SYNTH
    WAVE SAW
    ADSR 300 100 400 500
    VOLUME 160

SEQUENCE pluck_line:
    PLAY pluck C4 0.5
    PLAY pluck E4 0.5
    PLAY pluck G4 0.5
    PLAY pluck C5 0.5

SEQUENCE pad_line:
    PLAY pad [C3 E3 G3] 4

PLAY_SEQUENCE pluck_line
PLAY_SEQUENCE pad_line
